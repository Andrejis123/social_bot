# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.

# --- Supabase ---
# From Supabase project settings > API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use the service_role key for server-side inserts/updates.
# Keep this secret — it bypasses row-level security.
SUPABASE_SERVICE_KEY=eyJhbGciOi...
# Name of the Storage bucket for media files (create this in the Supabase dashboard first).
SUPABASE_MEDIA_BUCKET=media
# Name of the Storage bucket for generated report .pptx files. Auto-created
# on first upload as a PRIVATE bucket; access flows through 10-year signed URLs.
SUPABASE_REPORTS_BUCKET=reports

# --- Apify ---
# From https://console.apify.com/settings/integrations
APIFY_TOKEN=apify_api_...
# Primary Instagram actor — cheap, anonymous, no cookies.
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
# Fallback actor used when the primary returns 0 posts. Accepts cookies for
# authenticated scraping behind Instagram's anonymous rate limits.
APIFY_INSTAGRAM_FALLBACK_ACTOR=get-leads/all-in-one-instagram-scraper
# Facebook posts actor. The official actor returns full public-page history
# anonymously (verified). Restricted/age-gated pages are a future cookie'd tier.
APIFY_FACEBOOK_ACTOR=apify/facebook-posts-scraper
# Session cookies for the fallback. Paste a JSON array exported from Cookie-Editor.
# Must include a valid sessionid. Burner account recommended.
INSTAGRAM_COOKIES=
# 2-letter country code where the burner account logged in. The fallback's
# proxy uses this to match the cookie's origin IP — mismatch invalidates cookies.
INSTAGRAM_COOKIE_COUNTRY=SK
# Optional backup burner cookies (second account). Used when the primary
# cookie's admission gate denies (rate cap) or its cookies have expired.
# Each cookie has its own quota in the actor — backup = hot spare.
INSTAGRAM_COOKIES_BACKUP=
INSTAGRAM_COOKIE_COUNTRY_BACKUP=SK
# External residential proxy URL (provider-agnostic, e.g. IPRoyal). Country
# must be encoded in the URL (provider-specific: IPRoyal uses pass_country-XX).
# Format: http://user:pass@host:port. Empty = no proxy (proxyTier=none); works
# for public profiles but IG blocks restricted ones without a residential IP.
RESIDENTIAL_PROXY_URL=

# --- HikerAPI (managed instagrapi SaaS, posts top tier) ---
# When set, all post scraping tries HikerAPI first (handles restricted-but-
# public profiles via IG's mobile private API). Falls through to the Apify
# actors above on any error or empty result. Empty = legacy Apify-only flow.
# Pricing: $0.60 / 1000 requests, prepaid balance, no minimum.
# Dashboard: https://hikerapi.com/billing
HIKER_API_KEY=

# --- AI providers ---
# Gemini is the default for Phase 1 (cheap + strong on video).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI is the fallback / per-client override.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Google Drive (reports + content bundles + Live View) ---
# OAuth Desktop client credentials + long-lived refresh token. Mint the token
# once with `python scripts/_google_auth.py` (needs credentials.json from GCP;
# the OAuth app must be "In production" or refresh tokens expire in 7 days).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Drive folder names (created on first use under My Drive root).
GOOGLE_DRIVE_ROOT_FOLDER=SMM - Reports
GOOGLE_DRIVE_LIVE_ROOT_FOLDER=SMM - Live

# --- Telegram notifications (one-way bot; empty = notifications disabled) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Runtime ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Where per-client config lives. Override only if you move the folder.
CLIENTS_CONFIG_DIR=config/clients
